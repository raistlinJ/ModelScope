{
  "name": "Network Scan",
  "prompts": [
    "Scan my machine (127.0.0.1) with nmap using fast scan flags and tell me which ports are open."
  ],
  "commands": [],
  "validation_commands": ["nmap -F 127.0.0.1"],
  "fail_patterns": [
    {"type": "string",  "value": "failed"},
    {"type": "string",  "value": "unreachable"},
    {"type": "string",  "value": "refused"},
    {"type": "string",  "value": "no route"},
    {"type": "command", "value": "which nmap"}
  ],
  "metrics_matrix": [
    {"id": "M-001", "name": "Task Completion",        "type": "task_completion",       "enabled": true, "params": {}},
    {"id": "M-002", "name": "Tool Was Called",         "type": "tool_called",           "enabled": true, "params": {"tool_name": "run_nmap_scan"}},
    {"id": "M-003", "name": "Tool Call Count",         "type": "tool_call_count",       "enabled": true, "params": {"max_calls": 5}},
    {"id": "M-004", "name": "No Repeated Calls",       "type": "no_repeated_calls",     "enabled": true, "params": {}},
    {"id": "M-005", "name": "Max Iterations",          "type": "max_iterations",        "enabled": true, "params": {"max_iter": 10}},
    {"id": "M-006", "name": "Latency",                 "type": "latency",               "enabled": true, "params": {"max_seconds": 30.0}},
    {"id": "M-007", "name": "Token Limit",             "type": "token_limit",           "enabled": true, "params": {"max_tokens": 600}},
    {"id": "M-008", "name": "Content Contains Port",   "type": "content_contains",      "enabled": true, "params": {"text": "port"}},
    {"id": "M-009", "name": "Tool Usage Efficiency",   "type": "tool_usage_efficiency", "enabled": true, "params": {}},
    {"id": "M-010", "name": "Goal Achievement",        "type": "goal_achievement",      "enabled": true, "params": {}},
    {"id": "M-011", "name": "No Error Output",         "type": "no_error_output",       "enabled": true, "params": {}},
    {"id": "M-012", "name": "Path Efficiency",         "type": "path_efficiency",       "enabled": true, "params": {}}
  ]
}
